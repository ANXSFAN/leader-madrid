generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// --- Users & Auth ---

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  password      String? // Hashed password
  name          String?
  role          Role      @default(CUSTOMER)
  phone         String?
  customerLevel String?
  emailVerified DateTime?
  image         String? // OAuth profile picture

  // B2B Fields
  isActive            Boolean   @default(true)
  b2bStatus           B2BStatus @default(NOT_APPLIED)
  companyName         String?
  taxId               String? // CIF/VAT
  industry            String?
  registrationCountry String? // ISO 2-letter country code of VAT registration
  companyStreet       String? // Company registered address - street
  companyCity         String? // Company registered address - city
  companyZip          String? // Company registered address - zip
  phoneCountryCode    String? // Phone country code prefix e.g. "+34"
  vatVerified         Boolean   @default(false)
  vatVerifiedAt       DateTime?
  vatVerifiedName     String? // Name returned by VIES
  vatVerifiedAddress  String? // Address returned by VIES
  b2bAppliedAt        DateTime?
  b2bReviewedAt       DateTime?
  b2bRejectionReason  String?

  // Credit Management (B2B)
  creditLimit      Decimal?  @db.Decimal(10, 2) // null = no limit
  paymentTermsDays Int       @default(0) // 0 = prepay, 30/60/90 = net days
  currentBalance   Decimal   @default(0) @db.Decimal(10, 2) // outstanding amount owed

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  orders         Order[]
  salesOrders    SalesOrder[]
  addresses      Address[]
  priceLists     PriceList[]
  invoices       Invoice[]
  cart           Cart?
  returnRequests ReturnRequest[] @relation("UserReturns")
  rfqRequests    RFQRequest[]
  accounts       Account[]
  sessions       Session[]
  wishlistItems  WishlistItem[]
  customerTags   CustomerTag[]
  orderComments  OrderComment[]

  @@map("users")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  token     String   @unique
  email     String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
  @@map("password_reset_tokens")
}

model EmailVerificationToken {
  id        String   @id @default(uuid())
  token     String   @unique
  email     String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
  @@map("email_verification_tokens")
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

enum Role {
  CUSTOMER
  ADMIN
  SALES_REP
  WAREHOUSE_MANAGER
}

enum B2BStatus {
  NOT_APPLIED
  PENDING
  APPROVED
  REJECTED
}

model Address {
  id     String  @id @default(uuid())
  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  type      AddressType @default(SHIPPING)
  firstName String
  lastName  String
  company   String?
  street    String
  city      String
  state     String?
  zipCode   String
  country   String
  phone     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  ordersShipping Order[] @relation("ShippingAddress")
  ordersBilling  Order[] @relation("BillingAddress")

  @@index([userId])
  @@map("addresses")
}

enum ShippingStatus {
  PENDING
  PROCESSING
  SHIPPED
  IN_TRANSIT
  DELIVERED
  RETURNED
  FAILED
}

model ShippingMethod {
  id            String  @id @default(uuid())
  name          String
  description   String?
  price         Decimal @db.Decimal(10, 2)
  estimatedDays Int?
  isActive      Boolean @default(true)
  isDefault     Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders      Order[]      @relation("OrderShippingMethod")
  salesOrders SalesOrder[] @relation("SalesOrderShippingMethod")

  @@map("shipping_methods")
}

enum ProductType {
  SIMPLE
  BUNDLE
}

enum DocumentType {
  CERTIFICATE
  DATASHEET
  MANUAL
  PHOTOMETRIC
  OTHER
}

enum AddressType {
  SHIPPING
  BILLING
}

// --- Product Management (PIM) ---

model Product {
  id   String @id @default(uuid())
  slug String @unique
  sku  String @unique // Base SKU

  // Localized content (name, description, etc.) stored as JSONB
  // Example: { "en": { "name": "LED Bulb", "description": "..." }, "es": { "name": "Bombilla LED", ... } }
  content Json

  type       ProductType @default(SIMPLE)
  isActive   Boolean     @default(true)
  isFeatured Boolean     @default(false)
  brand      String?

  // Customs / HS Code
  hsCode String?

  sortOrder Int     @default(0)
  isPinned  Boolean @default(false)

  // Federation
  federationSource  String? // Source node ID (null = locally created)
  upstreamProductId String? // Product ID in the upstream instance

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  variants   ProductVariant[]
  category   Category?        @relation(fields: [categoryId], references: [id])
  categoryId String?

  supplier   Supplier? @relation(fields: [supplierId], references: [id])
  supplierId String?

  productSuppliers ProductSupplier[]
  bundleItems      BundleItem[]      @relation("BundleParent")
  wishlistItems    WishlistItem[]
  documents        ProductDocument[]
  channelProducts  ChannelProduct[]

  @@index([categoryId])
  @@index([supplierId])
  @@map("products")
}

model ProductDocument {
  id          String       @id @default(uuid())
  productId   String
  product     Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  type        DocumentType
  name        String
  url         String
  imageUrl    String?
  description String?
  sortOrder   Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([productId])
  @@map("product_documents")
}

model ProductVariant {
  id        String  @id @default(uuid())
  productId String
  product   Product @relation(fields: [productId], references: [id])

  sku String  @unique // Specific Variant SKU
  ean String? // Barcode

  // Pricing
  price          Decimal  @db.Decimal(10, 2) // RRP (Regular Price)
  b2bPrice       Decimal? @db.Decimal(10, 2) // Specific price for B2B customers
  compareAtPrice Decimal? @db.Decimal(10, 2)
  costPrice      Decimal? @db.Decimal(10, 2) // For internal ERP use (Purchase Price)

  // Inventory (Current Snapshot)
  physicalStock  Int @default(0)
  allocatedStock Int @default(0)
  minStock       Int @default(0) // Reorder point
  reorderPoint   Int @default(0) // Auto-reorder trigger point
  leadTimeDays   Int @default(14) // Supplier lead time in days

  // Technical Specifications stored as JSONB
  // Example: { "power": "10W", "cct": "3000K", "beamAngle": "120", "cri": ">80", "ip": "IP65" }
  specs Json

  // Variant specific content if needed
  content Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  inventoryLogs       InventoryTransaction[]
  orderItems          OrderItem[]
  purchaseOrderItems  PurchaseOrderItem[]
  salesOrderItems     SalesOrderItem[]
  priceListRules      PriceListRule[]
  bundleChildItems    BundleItem[]           @relation("BundleChild")
  cartItems           CartItem[]
  returnItems         ReturnItem[]           @relation("VariantReturns")
  warehouseStocks     WarehouseStock[]
  stockTransferItems  StockTransferItem[]
  deliveryOrderItems  DeliveryOrderItem[]
  purchaseReturnItems PurchaseReturnItem[]
  stockTakeItems      StockTakeItem[]
  inventoryLots       InventoryLot[]

  @@map("product_variants")
}

model Category {
  id      String @id @default(uuid())
  slug    String @unique
  content Json // Localized name/desc

  parentId String?
  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children Category[] @relation("CategoryHierarchy")

  products Product[]

  @@map("categories")
}

// --- Dynamic Attributes Dictionary ---

model AttributeDefinition {
  id           String  @id @default(uuid())
  name         Json // { "en": "Power", "es": "Potencia" }
  key          String  @unique // "power"
  type         String // "SELECT", "TEXT", "NUMBER"
  unit         String? // "W", "lm"
  scope        String // "PRODUCT", "VARIANT"
  isHighlight  Boolean @default(false) // Show as quick-spec pill on product page
  isFilterable Boolean @default(false) // Show as filter facet in search/category pages
  sortOrder    Int     @default(0)
  isPinned     Boolean @default(false)

  options AttributeOption[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("attribute_definitions")
}

model AttributeOption {
  id          String              @id @default(uuid())
  value       String
  color       String? // Hex code for color swatches
  attributeId String
  attribute   AttributeDefinition @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  @@map("attribute_options")
}

// --- Inventory & Supply Chain (ERP) ---

model Supplier {
  id      String @id @default(uuid())
  name    String
  code    String @unique // Internal Supplier Code
  contact Json? // { "email": "...", "phone": "..." }
  address Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products         Product[]
  purchaseOrders   PurchaseOrder[]
  productSuppliers ProductSupplier[]
  purchaseReturns  PurchaseReturn[]
  federationNode   FederationNode?

  @@map("suppliers")
}

model PurchaseOrder {
  id         String   @id @default(uuid())
  poNumber   String   @unique
  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id])

  warehouseId String?
  warehouse   Warehouse? @relation(fields: [warehouseId], references: [id])

  source       String   @default("PO") // 'PO' = normal purchase order, 'QUICK' = quick stock-in
  status       POStatus @default(DRAFT)
  totalAmount  Decimal  @db.Decimal(10, 2)
  currency     String   @default("EUR")
  exchangeRate Decimal  @default(1.0) @db.Decimal(10, 4)

  items               PurchaseOrderItem[]
  purchaseReturns     PurchaseReturn[]
  customsDeclarations CustomsDeclaration[]

  // Import / Customs (optional)
  customsDeclarationNumber String?
  customsClearedAt         DateTime?
  dutyAmount               Decimal?  @db.Decimal(10, 2)
  customsServiceFee        Decimal?  @db.Decimal(10, 2)
  customsNotes             String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([warehouseId])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id   String        @id @default(uuid())
  poId String
  po   PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)

  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id])

  quantity    Int
  receivedQty Int     @default(0) // Partial receiving support
  costPrice   Decimal @db.Decimal(10, 2) // Unit cost
  total       Decimal @db.Decimal(10, 2) // quantity * costPrice

  name String? // Snapshot of product name
  sku  String? // Snapshot of variant SKU

  @@map("purchase_order_items")
}

enum POStatus {
  DRAFT
  SENT
  PARTIAL_RECEIVED
  RECEIVED
  CANCELLED
}

model SalesOrder {
  id          String @id @default(uuid())
  orderNumber String @unique
  customerId  String
  customer    User   @relation(fields: [customerId], references: [id])

  warehouseId String?
  warehouse   Warehouse? @relation(fields: [warehouseId], references: [id])

  status       SOStatus @default(DRAFT)
  totalAmount  Decimal  @db.Decimal(10, 2)
  subtotal     Decimal? @db.Decimal(10, 2)
  tax          Decimal? @db.Decimal(10, 2)
  shipping     Decimal? @db.Decimal(10, 2)
  currency     String   @default("EUR")
  exchangeRate Decimal  @default(1.0) @db.Decimal(10, 4)

  // Shipping & Tracking
  shippingMethodId String?
  shippingMethod   ShippingMethod? @relation("SalesOrderShippingMethod", fields: [shippingMethodId], references: [id])
  trackingNumber   String?
  trackingUrl      String?
  shippingStatus   ShippingStatus  @default(PENDING)
  shippedAt        DateTime?
  deliveredAt      DateTime?

  items               SalesOrderItem[]
  invoices            Invoice[]
  customsDeclarations CustomsDeclaration[]
  deliveryOrders      DeliveryOrder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
  @@index([status])
  @@index([warehouseId])
  @@map("sales_orders")
}

model SalesOrderItem {
  id   String     @id @default(uuid())
  soId String
  so   SalesOrder @relation(fields: [soId], references: [id], onDelete: Cascade)

  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id])

  quantity  Int
  unitPrice Decimal  @db.Decimal(10, 2)
  costPrice Decimal? @db.Decimal(10, 2) // Snapshot of variant costPrice at order time
  total     Decimal  @db.Decimal(10, 2) // quantity * unitPrice

  name  String? // Snapshot of product name
  sku   String? // Snapshot of variant SKU
  image String? // Snapshot of product image URL

  @@map("sales_order_items")
}

enum SOStatus {
  DRAFT
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
}

model InventoryTransaction {
  id        String         @id @default(uuid())
  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id])

  warehouseId String?
  warehouse   Warehouse? @relation(fields: [warehouseId], references: [id])

  quantity  Int // Positive for IN, Negative for OUT
  type      InventoryType
  reference String? // Order ID, PO Number, or Reason
  note      String?

  createdAt DateTime @default(now())
  createdBy String? // User ID of staff

  @@index([variantId])
  @@index([warehouseId])
  @@map("inventory_transactions")
}

enum InventoryType {
  PURCHASE_ORDER // IN
  SALE_ORDER // OUT
  ADJUSTMENT // Manual fix
  RETURN // IN (Customer Return)
  DAMAGED // OUT
  TRANSFER // Warehouse transfer
  STOCK_TAKE // Stock take adjustment
  PURCHASE_RETURN // Return to supplier
}

// --- Sales & Finance (ERP) ---

model Order {
  id          String @id @default(uuid())
  orderNumber String @unique // Friendly ID like #1001

  userId String? // Nullable for guest checkout
  user   User?   @relation(fields: [userId], references: [id])

  // Financials
  subtotal     Decimal @db.Decimal(10, 2)
  tax          Decimal @db.Decimal(10, 2) // IVA
  shipping     Decimal @db.Decimal(10, 2)
  total        Decimal @db.Decimal(10, 2)
  currency     String  @default("EUR")
  exchangeRate Decimal @default(1.0) @db.Decimal(10, 4)

  status        OrderStatus   @default(PENDING)
  paymentStatus PaymentStatus @default(PENDING)
  paymentMethod String? // "STRIPE", "BANK_TRANSFER"
  poNumber      String? // B2B Purchase Order Number
  rfqId         String? // Converted from RFQ
  rfq           RFQRequest?   @relation(fields: [rfqId], references: [id])

  // VAT / Tax
  vatRate         Decimal @default(21.00) @db.Decimal(5, 2)
  isReverseCharge Boolean @default(false)
  buyerVatNumber  String?

  // Logistics
  shippingAddressId String?
  shippingAddress   Address? @relation("ShippingAddress", fields: [shippingAddressId], references: [id])
  billingAddressId  String?
  billingAddress    Address? @relation("BillingAddress", fields: [billingAddressId], references: [id])

  // Shipping & Tracking
  shippingMethodId String?
  shippingMethod   ShippingMethod? @relation("OrderShippingMethod", fields: [shippingMethodId], references: [id])
  trackingNumber   String?
  trackingUrl      String?
  shippingStatus   ShippingStatus  @default(PENDING)
  shippedAt        DateTime?
  deliveredAt      DateTime?

  // Internal
  internalNotes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items               OrderItem[]
  returnRequests      ReturnRequest[]
  paymentTransactions PaymentTransaction[]
  comments            OrderComment[]

  @@index([userId])
  @@index([status])
  @@map("orders")
}

model OrderItem {
  id      String @id @default(uuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id])

  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id])

  quantity  Int
  price     Decimal  @db.Decimal(10, 2) // Price at moment of purchase
  costPrice Decimal? @db.Decimal(10, 2) // Cost price at moment of purchase (for margin analysis)
  total     Decimal  @db.Decimal(10, 2)

  name  String // Snapshot of product name
  sku   String // Snapshot of SKU
  image String? // Snapshot of product image URL

  @@map("order_items")
}

enum OrderStatus {
  DRAFT
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

// --- Pricing System ---

model PriceList {
  id              String  @id @default(uuid())
  name            String
  currency        String  @default("EUR")
  isDefault       Boolean @default(false)
  levelCode       String?
  discountPercent Decimal @default(0) @db.Decimal(5, 2)

  users User[]
  rules PriceListRule[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("price_lists")
}

model PriceListRule {
  id          String    @id @default(uuid())
  priceListId String
  priceList   PriceList @relation(fields: [priceListId], references: [id], onDelete: Cascade)

  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  price       Decimal @db.Decimal(10, 2)
  minQuantity Int     @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([priceListId, variantId, minQuantity])
  @@map("price_list_rules")
}

// --- Product Bundles ---

model BundleItem {
  id String @id @default(uuid())

  parentId String
  parent   Product @relation("BundleParent", fields: [parentId], references: [id], onDelete: Cascade)

  childId String
  child   ProductVariant @relation("BundleChild", fields: [childId], references: [id])

  quantity Int @default(1)

  @@unique([parentId, childId])
  @@map("bundle_items")
}

// --- Supplier Management ---

model ProductSupplier {
  id String @id @default(uuid())

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  supplierSku String?
  costPrice   Decimal? @db.Decimal(10, 2)
  moq         Int      @default(1)

  isPrimary Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, supplierId])
  @@map("product_suppliers")
}

// --- Invoicing & Payments ---

model Invoice {
  id            String @id @default(uuid())
  invoiceNumber String @unique

  // Invoice type (RD 1619/2012)
  invoiceType InvoiceType @default(STANDARD)

  // Self-relation for rectificative invoices (Art. 15 RD 1619/2012)
  originalInvoiceId   String?
  originalInvoice     Invoice?  @relation("InvoiceRectification", fields: [originalInvoiceId], references: [id])
  rectifications      Invoice[] @relation("InvoiceRectification")
  rectificationReason String? // Reason for correction (required for rectificativas)

  salesOrderId String
  salesOrder   SalesOrder @relation(fields: [salesOrderId], references: [id])

  customerId String
  customer   User   @relation(fields: [customerId], references: [id])

  status InvoiceStatus @default(DRAFT)

  issueDate DateTime @default(now())
  dueDate   DateTime

  totalAmount  Decimal  @db.Decimal(10, 2)
  subtotal     Decimal? @db.Decimal(10, 2)
  tax          Decimal? @db.Decimal(10, 2)
  shipping     Decimal? @db.Decimal(10, 2)
  currency     String   @default("EUR")
  exchangeRate Decimal  @default(1.0) @db.Decimal(10, 4)
  paidAmount   Decimal  @default(0) @db.Decimal(10, 2)

  // Tax compliance snapshots (RD 1619/2012)
  vatRate           Decimal @default(21.00) @db.Decimal(5, 2)
  isReverseCharge   Boolean @default(false)
  isExempt          Boolean @default(false) // Export outside EU (art. 21 LIVA)
  vatLabel          String? // e.g. "IVA 21%", "Inversión del Sujeto Pasivo (0%)"
  vatLegalNote      String? // Legal basis text for exemption/reverse charge
  buyerVatNumber    String?
  buyerCountry      String? // ISO 2-letter code, for VAT determination audit
  sellerSnapshot    Json? // Frozen seller info: name, address, taxId
  buyerSnapshot     Json? // Frozen buyer info: name, company, address, taxId
  lineItemsSnapshot Json? // Frozen line items: [{name, sku, qty, unitPrice, total, vatRate}]

  // Multi-VAT rate breakdown (when items have different VAT rates)
  vatBreakdown Json? // [{vatRate: number, base: string, amount: string}]

  // Integrity & VeriFactu preparation (Ley 11/2021)
  integrityHash   String? // SHA-256 hash of immutable financial data
  previousHash    String? // Hash of the previous invoice in chain (VeriFactu)
  verifactuId     String? // VeriFactu registration ID (assigned by AEAT)
  verifactuQrData String? // Data for VeriFactu QR code verification

  payments Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([salesOrderId])
  @@index([customerId])
  @@index([originalInvoiceId])
  @@map("invoices")
}

model InvoiceCounter {
  id      String @default("default") // "default" | "RECT" | "FS"
  year    Int
  lastSeq Int    @default(0)

  @@id([id, year])
  @@map("invoice_counters")
}

enum InvoiceType {
  STANDARD // Factura completa (standard)
  RECTIFICATIVA // Factura rectificativa (credit note / correction)
  SIMPLIFICADA // Factura simplificada (simplified, <400€ B2C)
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  PARTIALLY_PAID
  OVERDUE
  CANCELLED
}

model Payment {
  id String @id @default(uuid())

  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  amount Decimal @db.Decimal(10, 2)
  method String // "BANK_TRANSFER", "CASH", "STRIPE", etc.
  note   String?

  date DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("payments")
}

model PaymentTransaction {
  id String @id @default(uuid())

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  provider              String
  providerTransactionId String?
  status                PaymentStatus @default(PENDING)
  amount                Decimal       @db.Decimal(10, 2)
  currency              String        @default("EUR")
  metadata              Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([provider, providerTransactionId])
  @@index([orderId])
  @@map("payment_transactions")
}

model PaymentWebhookEvent {
  id String @id @default(uuid())

  provider  String
  eventId   String
  eventType String?
  payload   Json

  receivedAt DateTime @default(now())

  @@unique([provider, eventId])
  @@map("payment_webhook_events")
}

// --- CMS & Marketing ---

model Banner {
  id       String  @id @default(uuid())
  title    String // 内部管理名称
  imageUrl String // 背景图
  order    Int     @default(0)
  isActive Boolean @default(true)

  // 核心视觉配置 (JSON)
  // 结构:
  // {
  //   badge: string, // 顶部小标签 (e.g. "NEW ARRIVAL")
  //   heading: string, // 主标题 (支持简单 HTML)
  //   highlightColor: string, // 高亮色 (e.g. "text-yellow-400")
  //   description: string,
  //   buttons: [
  //     { text: string, link: string, variant: "primary" | "outline" }
  //   ],
  //   stats: [ // 底部信任指标
  //     { label: string, value: string, icon: string } // icon: "ShieldCheck", "Zap", etc.
  //   ],
  //   alignment: "left" | "center"
  // }
  content Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("banners")
}

model GlobalConfig {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt

  @@map("global_configs")
}

model NewsletterSubscription {
  id        String   @id @default(uuid())
  email     String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("newsletter_subscriptions")
}

// --- Cart System ---

model Cart {
  id     String     @id @default(uuid())
  userId String     @unique
  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items  CartItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("carts")
}

model CartItem {
  id     String @id @default(uuid())
  cartId String
  cart   Cart   @relation(fields: [cartId], references: [id], onDelete: Cascade)

  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id])

  quantity Int @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cartId, variantId])
  @@map("cart_items")
}

// --- EU VAT Configuration ---

model CountryVATConfig {
  id           String   @id @default(uuid())
  countryCode  String   @unique // ISO 3166-1 alpha-2
  countryName  String
  standardRate Decimal  @db.Decimal(5, 2)
  reducedRate  Decimal? @db.Decimal(5, 2)
  isEU         Boolean  @default(true)
  isActive     Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("country_vat_configs")
}

// --- Returns / RMA ---

enum ReturnStatus {
  REQUESTED
  APPROVED
  REJECTED
  RECEIVED
  REFUNDED
  CLOSED
}

enum ReturnReason {
  DEFECTIVE
  WRONG_ITEM
  NOT_AS_DESCRIBED
  DAMAGED_IN_TRANSIT
  CHANGED_MIND
  OTHER
}

model ReturnRequest {
  id           String @id @default(uuid())
  returnNumber String @unique

  orderId String
  order   Order  @relation(fields: [orderId], references: [id])

  userId String
  user   User   @relation("UserReturns", fields: [userId], references: [id])

  warehouseId String?
  warehouse   Warehouse? @relation(fields: [warehouseId], references: [id])

  status       ReturnStatus @default(REQUESTED)
  reason       ReturnReason
  notes        String?
  adminNotes   String?
  refundAmount Decimal?     @db.Decimal(10, 2)

  items ReturnItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([orderId])
  @@index([warehouseId])
  @@map("return_requests")
}

model ReturnItem {
  id              String        @id @default(uuid())
  returnRequestId String
  returnRequest   ReturnRequest @relation(fields: [returnRequestId], references: [id], onDelete: Cascade)

  variantId String
  variant   ProductVariant @relation("VariantReturns", fields: [variantId], references: [id])

  orderItemId String?
  quantity    Int
  restockQty  Int     @default(0)
  condition   String?

  name  String? // Snapshot of product name
  sku   String? // Snapshot of variant SKU
  image String? // Snapshot of product image URL

  @@map("return_items")
}

enum RFQStatus {
  PENDING
  REVIEWING
  QUOTED
  ACCEPTED
  REJECTED
  EXPIRED
}

model RFQRequest {
  id     String  @id @default(uuid())
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  contactName  String
  contactEmail String
  companyName  String?
  phone        String?
  country      String  @default("ES")
  message      String?

  status      RFQStatus @default(PENDING)
  adminNote   String?
  quotedTotal Decimal?

  items  RFQItem[]
  orders Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("rfq_requests")
}

model RFQItem {
  id    String     @id @default(uuid())
  rfqId String
  rfq   RFQRequest @relation(fields: [rfqId], references: [id], onDelete: Cascade)

  productId   String
  productName String
  variantId   String?
  variantSku  String?
  quantity    Int      @default(1)
  targetPrice Decimal?

  @@index([rfqId])
  @@map("rfq_items")
}

// --- Wishlist ---

model WishlistItem {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId])
  @@map("wishlist_items")
}

// --- Contact Submissions ---

enum ContactStatus {
  NEW
  READ
  REPLIED
}

model ContactSubmission {
  id        String        @id @default(uuid())
  name      String
  email     String
  company   String?
  phone     String?
  subject   String
  message   String        @db.Text
  status    ContactStatus @default(NEW)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([status])
  @@index([createdAt])
  @@map("contact_submissions")
}

// --- Exchange Rates ---

model ExchangeRate {
  id               String   @id @default(uuid())
  currency         String // "GBP", "PLN", etc.
  rate             Decimal  @db.Decimal(12, 6) // 1 EUR = X target currency
  source           String   @default("ECB") // "ECB" | "MANUAL"
  date             DateTime @db.Date
  isManualOverride Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([currency, date])
  @@index([currency])
  @@map("exchange_rates")
}

// --- CMS Pages ---

enum CmsPageType {
  SOLUTION
  RESOURCE
  LEGAL
  GENERAL
}

model CmsPage {
  id            String      @id @default(uuid())
  slug          String      @unique
  type          CmsPageType
  content       Json
  attachmentUrl String?
  imageUrl      String?
  order         Int         @default(0)
  isActive      Boolean     @default(true)
  menuGroup     String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([type])
  @@index([menuGroup])
  @@index([slug])
  @@map("cms_pages")
}

// --- Warehouses & Stock Transfers ---

model Warehouse {
  id        String   @id @default(uuid())
  name      String
  code      String   @unique // e.g. "WH-MAIN", "WH-EU"
  address   String?
  city      String?
  country   String?
  isDefault Boolean  @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stockEntries    WarehouseStock[]
  transactions    InventoryTransaction[]
  outTransfers    StockTransfer[]        @relation("TransferFrom")
  inTransfers     StockTransfer[]        @relation("TransferTo")
  purchaseOrders  PurchaseOrder[]
  salesOrders     SalesOrder[]
  returnRequests  ReturnRequest[]
  deliveryOrders  DeliveryOrder[]
  stockTakes      StockTake[]
  purchaseReturns PurchaseReturn[]
  binLocations    BinLocation[]

  @@map("warehouses")
}

model WarehouseStock {
  id             String @id @default(uuid())
  warehouseId    String
  variantId      String
  physicalStock  Int    @default(0)
  allocatedStock Int    @default(0)
  minStock       Int    @default(0)

  warehouse Warehouse      @relation(fields: [warehouseId], references: [id])
  variant   ProductVariant @relation(fields: [variantId], references: [id])

  @@unique([warehouseId, variantId])
  @@index([variantId])
  @@index([warehouseId])
  @@map("warehouse_stocks")
}

enum TransferStatus {
  PENDING
  IN_TRANSIT
  COMPLETED
  CANCELLED
}

model StockTransfer {
  id              String         @id @default(uuid())
  transferNumber  String         @unique
  fromWarehouseId String
  toWarehouseId   String
  status          TransferStatus @default(PENDING)
  note            String?
  createdBy       String?
  createdAt       DateTime       @default(now())
  completedAt     DateTime?

  fromWarehouse Warehouse           @relation("TransferFrom", fields: [fromWarehouseId], references: [id])
  toWarehouse   Warehouse           @relation("TransferTo", fields: [toWarehouseId], references: [id])
  items         StockTransferItem[]

  @@index([fromWarehouseId])
  @@index([toWarehouseId])
  @@index([status])
  @@map("stock_transfers")
}

model StockTransferItem {
  id         String @id @default(uuid())
  transferId String
  variantId  String
  quantity   Int

  transfer StockTransfer  @relation(fields: [transferId], references: [id], onDelete: Cascade)
  variant  ProductVariant @relation(fields: [variantId], references: [id])

  @@map("stock_transfer_items")
}

// --- Audit Log ---

model AuditLog {
  id         String   @id @default(uuid())
  entityType String // "PRODUCT", "ORDER", etc.
  entityId   String
  action     String // "CREATE", "UPDATE", "DELETE", "STATUS_CHANGE"
  changes    Json? // { field: { old: ..., new: ... } }
  userId     String?
  userName   String?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// --- Customs Clearance ---

enum CustomsDeclarationType {
  IMPORT
  EXPORT
}

enum CustomsStatus {
  DRAFT
  SUBMITTED
  INSPECTING
  CLEARED
  HELD
  RELEASED
}

enum CustomsShippingMethod {
  SEA
  AIR
  ROAD
  RAIL
}

model CustomsDeclaration {
  id                String                 @id @default(uuid())
  declarationNumber String                 @unique
  type              CustomsDeclarationType
  status            CustomsStatus          @default(DRAFT)

  // Related orders
  purchaseOrderId String?
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
  salesOrderId    String?
  salesOrder      SalesOrder?    @relation(fields: [salesOrderId], references: [id])

  // Customs info
  customsOffice      String?
  entryPort          String?
  countryOfOrigin    String?
  destinationCountry String?

  // Financial
  declaredValue Decimal  @db.Decimal(12, 2)
  currency      String   @default("EUR")
  dutyRate      Decimal? @db.Decimal(5, 2)
  dutyAmount    Decimal? @db.Decimal(10, 2)
  vatAmount     Decimal? @db.Decimal(10, 2)
  otherCharges  Decimal? @db.Decimal(10, 2)
  totalCost     Decimal? @db.Decimal(12, 2)

  // Logistics
  trackingNumber   String?
  shippingMethod   CustomsShippingMethod?
  estimatedArrival DateTime?
  actualArrival    DateTime?

  // Broker
  brokerName    String?
  brokerContact String?

  // Documents (JSON array of { type, name, url })
  documents Json?

  // Notes
  notes String?

  // Timeline
  submittedAt DateTime?
  clearedAt   DateTime?

  // Items
  items CustomsDeclarationItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([type])
  @@index([purchaseOrderId])
  @@index([salesOrderId])
  @@map("customs_declarations")
}

model CustomsDeclarationItem {
  id            String             @id @default(uuid())
  declarationId String
  declaration   CustomsDeclaration @relation(fields: [declarationId], references: [id], onDelete: Cascade)

  productName     String
  sku             String?
  hsCode          String?
  quantity        Int
  unitPrice       Decimal  @db.Decimal(10, 2)
  totalValue      Decimal  @db.Decimal(12, 2)
  weight          Decimal? @db.Decimal(10, 3)
  countryOfOrigin String?

  @@map("customs_declaration_items")
}

// --- Delivery Orders (Outbound) ---

enum DeliveryOrderStatus {
  DRAFT
  CONFIRMED
  PICKING
  PACKED
  SHIPPED
  DELIVERED
  CANCELLED
}

model DeliveryOrder {
  id             String              @id @default(uuid())
  deliveryNumber String              @unique
  salesOrderId   String
  salesOrder     SalesOrder          @relation(fields: [salesOrderId], references: [id])
  warehouseId    String
  warehouse      Warehouse           @relation(fields: [warehouseId], references: [id])
  status         DeliveryOrderStatus @default(DRAFT)

  // Shipping info
  trackingNumber String?
  carrierName    String?
  shippingNote   String?

  // Timestamps
  confirmedAt DateTime?
  pickedAt    DateTime?
  packedAt    DateTime?
  shippedAt   DateTime?
  deliveredAt DateTime?

  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items DeliveryOrderItem[]

  @@index([salesOrderId])
  @@index([warehouseId])
  @@index([status])
  @@map("delivery_orders")
}

model DeliveryOrderItem {
  id              String         @id @default(uuid())
  deliveryOrderId String
  deliveryOrder   DeliveryOrder  @relation(fields: [deliveryOrderId], references: [id], onDelete: Cascade)
  variantId       String
  variant         ProductVariant @relation(fields: [variantId], references: [id])

  orderedQty   Int // Original SO quantity
  deliveredQty Int // Qty in this delivery

  // Snapshot
  sku  String?
  name String?

  @@map("delivery_order_items")
}

// --- Stock Take (Inventory Count) ---

enum StockTakeStatus {
  DRAFT
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model StockTake {
  id              String          @id @default(uuid())
  stockTakeNumber String          @unique
  warehouseId     String
  warehouse       Warehouse       @relation(fields: [warehouseId], references: [id])
  status          StockTakeStatus @default(DRAFT)

  note String?

  // Summary (computed on completion)
  totalVariants      Int @default(0)
  totalDiscrepancies Int @default(0)

  createdBy   String?
  completedBy String?
  createdAt   DateTime  @default(now())
  completedAt DateTime?
  updatedAt   DateTime  @updatedAt

  items StockTakeItem[]

  @@index([warehouseId])
  @@index([status])
  @@map("stock_takes")
}

model StockTakeItem {
  id          String         @id @default(uuid())
  stockTakeId String
  stockTake   StockTake      @relation(fields: [stockTakeId], references: [id], onDelete: Cascade)
  variantId   String
  variant     ProductVariant @relation(fields: [variantId], references: [id])

  systemQty   Int // System stock at time of count
  countedQty  Int? // Actual physical count (null = not yet counted)
  discrepancy Int? // countedQty - systemQty (computed on save)

  note      String?
  countedAt DateTime?
  countedBy String?

  @@unique([stockTakeId, variantId])
  @@map("stock_take_items")
}

// --- Purchase Returns ---

enum PurchaseReturnStatus {
  DRAFT
  CONFIRMED
  SHIPPED_TO_SUPPLIER
  RECEIVED_BY_SUPPLIER
  REFUNDED
  CANCELLED
}

model PurchaseReturn {
  id              String               @id @default(uuid())
  returnNumber    String               @unique
  purchaseOrderId String
  purchaseOrder   PurchaseOrder        @relation(fields: [purchaseOrderId], references: [id])
  supplierId      String
  supplier        Supplier             @relation(fields: [supplierId], references: [id])
  warehouseId     String
  warehouse       Warehouse            @relation(fields: [warehouseId], references: [id])
  status          PurchaseReturnStatus @default(DRAFT)

  reason      String?
  totalAmount Decimal @db.Decimal(10, 2)

  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items PurchaseReturnItem[]

  @@index([purchaseOrderId])
  @@index([supplierId])
  @@index([warehouseId])
  @@map("purchase_returns")
}

model PurchaseReturnItem {
  id               String         @id @default(uuid())
  purchaseReturnId String
  purchaseReturn   PurchaseReturn @relation(fields: [purchaseReturnId], references: [id], onDelete: Cascade)
  variantId        String
  variant          ProductVariant @relation(fields: [variantId], references: [id])

  quantity  Int
  costPrice Decimal @db.Decimal(10, 2)
  total     Decimal @db.Decimal(10, 2)

  reason String?
  sku    String?
  name   String?

  @@map("purchase_return_items")
}

// --- Batch/Lot Tracking ---

model InventoryLot {
  id          String         @id @default(uuid())
  lotNumber   String         @unique
  variantId   String
  variant     ProductVariant @relation(fields: [variantId], references: [id])
  warehouseId String

  // Bin location linkage (tracks which shelf/zone the lot is stored in)
  binLocationId String?
  binLocation   BinLocation? @relation(fields: [binLocationId], references: [id])

  quantity        Int @default(0) // Current lot quantity
  initialQuantity Int // Original quantity when created

  manufacturingDate DateTime?
  expiryDate        DateTime?

  // Traceability
  supplierId      String?
  purchaseOrderId String?
  reference       String? // PO number etc.

  note String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([variantId])
  @@index([warehouseId])
  @@index([binLocationId])
  @@index([lotNumber])
  @@map("inventory_lots")
}

// --- Bin Location (Warehouse Sub-locations) ---

model BinLocation {
  id          String    @id @default(uuid())
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])

  code  String // e.g. "A-01-03" (Zone-Row-Shelf)
  zone  String? // e.g. "A", "B", "RECEIVING", "SHIPPING"
  aisle String? // e.g. "01"
  shelf String? // e.g. "03"

  description String?
  isActive    Boolean @default(true)

  lots InventoryLot[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([warehouseId, code])
  @@index([warehouseId])
  @@map("bin_locations")
}

// --- Approval Workflow ---

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model ApprovalRequest {
  id         String         @id @default(uuid())
  entityType String // "PURCHASE_ORDER", "DELIVERY_ORDER", "STOCK_ADJUSTMENT"
  entityId   String
  status     ApprovalStatus @default(PENDING)

  // Threshold that triggered approval
  reason String? // e.g. "PO amount exceeds 5000 EUR"

  requestedBy String
  approvedBy  String?

  comments String?

  requestedAt DateTime  @default(now())
  resolvedAt  DateTime?

  @@index([entityType, entityId])
  @@index([status])
  @@index([requestedBy])
  @@map("approval_requests")
}

// --- Federation (Multi-Instance ERP Network) ---

enum FederationNodeType {
  UPSTREAM
  DOWNSTREAM
}

enum FederationStatus {
  PENDING
  ACTIVE
  SUSPENDED
  REVOKED
}

model FederationNode {
  id   String             @id @default(uuid())
  name String
  code String             @unique
  type FederationNodeType

  // Connection
  baseUrl    String
  apiKey     String
  apiSecret  String
  inboundKey String @unique

  // Status
  status     FederationStatus @default(PENDING)
  lastSyncAt DateTime?
  lastError  String?

  // Business terms
  defaultCurrency  String   @default("EUR")
  paymentTermsDays Int      @default(30)
  creditLimit      Decimal? @db.Decimal(12, 2)

  // Link to Supplier record (when this node acts as our supplier)
  supplierId String?   @unique
  supplier   Supplier? @relation(fields: [supplierId], references: [id])

  channels    SupplyChannel[]
  orders      FederationOrder[]
  syncLogs    FederationSyncLog[]
  settlements FederationSettlement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("federation_nodes")
}

model FederationSyncLog {
  id     String         @id @default(uuid())
  nodeId String
  node   FederationNode @relation(fields: [nodeId], references: [id])

  direction  String // "INBOUND" | "OUTBOUND"
  entityType String // "PRODUCT" | "ORDER" | "STATUS" | "INVENTORY"
  entityId   String?
  action     String // "SYNC" | "CREATE" | "UPDATE" | "ACK"
  status     String // "SUCCESS" | "FAILED" | "RETRY"
  payload    Json?
  errorMsg   String?

  createdAt DateTime @default(now())

  @@index([nodeId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("federation_sync_logs")
}

enum SyncStatus {
  PENDING
  SYNCED
  MODIFIED
  CONFLICT
  DISABLED
}

model SupplyChannel {
  id     String         @id @default(uuid())
  name   String
  nodeId String
  node   FederationNode @relation(fields: [nodeId], references: [id])

  isPublished  Boolean @default(false)
  isSubscribed Boolean @default(false)
  autoSync     Boolean @default(true)
  syncPricing  Boolean @default(false)

  products ChannelProduct[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([nodeId, name])
  @@map("supply_channels")
}

model ChannelProduct {
  id        String        @id @default(uuid())
  channelId String
  channel   SupplyChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  upstreamProductId String
  upstreamSku       String

  localProductId String?
  localProduct   Product? @relation(fields: [localProductId], references: [id])

  lastSyncedAt DateTime?
  syncHash     String?
  syncStatus   SyncStatus @default(PENDING)

  priceMarkupPercent Decimal? @db.Decimal(5, 2)
  priceOverride      Decimal? @db.Decimal(10, 2)

  contentOverride Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([channelId, upstreamProductId])
  @@index([localProductId])
  @@map("channel_products")
}

model FederationOrder {
  id String @id @default(uuid())

  localOrderId      String?
  localPOId         String?
  remoteOrderId     String?
  remoteOrderNumber String?

  nodeId String
  node   FederationNode @relation(fields: [nodeId], references: [id])

  direction String // "OUTBOUND_PO" | "INBOUND_SO"
  status    FederationOrderStatus @default(PENDING)

  totalAmount Decimal @db.Decimal(12, 2)
  currency    String  @default("EUR")

  items         FederationOrderItem[]
  statusHistory FederationOrderStatusHistory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([nodeId])
  @@index([localOrderId])
  @@index([localPOId])
  @@index([remoteOrderId])
  @@map("federation_orders")
}

model FederationOrderItem {
  id                String          @id @default(uuid())
  federationOrderId String
  federationOrder   FederationOrder @relation(fields: [federationOrderId], references: [id], onDelete: Cascade)

  upstreamVariantId String
  localVariantId    String?
  quantity          Int
  unitPrice         Decimal @db.Decimal(10, 2)
  total             Decimal @db.Decimal(10, 2)
  sku               String?
  name              String?

  @@map("federation_order_items")
}

model FederationOrderStatusHistory {
  id                String          @id @default(uuid())
  federationOrderId String
  federationOrder   FederationOrder @relation(fields: [federationOrderId], references: [id], onDelete: Cascade)

  fromStatus String?
  toStatus   String
  source     String // "LOCAL" | "REMOTE"
  note       String?

  createdAt DateTime @default(now())

  @@map("federation_order_status_history")
}

enum FederationOrderStatus {
  PENDING
  SENT
  ACKNOWLEDGED
  PROCESSING
  PARTIALLY_SHIPPED
  SHIPPED
  DELIVERED
  CANCELLED
  DISPUTED
}

model FederationSettlement {
  id               String         @id @default(uuid())
  settlementNumber String         @unique
  nodeId           String
  node             FederationNode @relation(fields: [nodeId], references: [id])

  periodStart DateTime
  periodEnd   DateTime
  status      SettlementStatus @default(DRAFT)

  totalOrders Int
  totalAmount Decimal @db.Decimal(12, 2)
  currency    String  @default("EUR")

  lineItems FederationSettlementLine[]

  localConfirmedAt  DateTime?
  remoteConfirmedAt DateTime?
  localConfirmedBy  String?
  note              String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([nodeId])
  @@index([status])
  @@map("federation_settlements")
}

model FederationSettlementLine {
  id           String               @id @default(uuid())
  settlementId String
  settlement   FederationSettlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)

  federationOrderId String?
  orderNumber       String
  orderDate         DateTime
  amount            Decimal  @db.Decimal(12, 2)
  status            String // "AGREED" | "DISPUTED"
  note              String?

  @@map("federation_settlement_lines")
}

enum SettlementStatus {
  DRAFT
  SENT
  UNDER_REVIEW
  AGREED
  DISPUTED
  SETTLED
}

// --- Customer Tags ---

model CustomerTag {
  id    String @id @default(uuid())
  name  String @unique
  color String @default("#3b82f6")

  users User[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("customer_tags")
}

// --- Order Comments ---

model OrderComment {
  id      String @id @default(uuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  userId  String
  user    User   @relation(fields: [userId], references: [id])
  content String

  createdAt DateTime @default(now())

  @@index([orderId])
  @@map("order_comments")
}
