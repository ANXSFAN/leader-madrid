DATABASE_URL=postgresql://user:password@host:6543/postgres
DIRECT_URL=postgresql://user:password@host:5432/postgres

# Next Auth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-random-secret-here"

# Email (Resend)
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=noreply@yourdomain.com
ADMIN_EMAIL=admin@yourdomain.com

# Typesense Search (Cloud)
TYPESENSE_HOST=your-cluster-id.a2.typesense.net
TYPESENSE_PORT=443
TYPESENSE_PROTOCOL=https
TYPESENSE_API_KEY=your_typesense_api_key

# OpenRouter API
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_api_key
OPENROUTER_MODEL=google/gemini-3-flash-preview

# Logistics
SENDCLOUD_PUBLIC_KEY=your_sendcloud_public_key
SENDCLOUD_SECRET_KEY=your_sendcloud_secret_key
LOGISTICS_ADAPTER=mock

# Supabase Storage
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Cron Jobs
CRON_SECRET=generate-a-random-secret-min-32-chars

# Public App URL (used for emails, OG images, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Payment — Cecabank TPV Virtual
PAYMENT_PROVIDER=CECABANK
CECABANK_MERCHANT_ID=
CECABANK_ACQUIRER_BIN=
CECABANK_TERMINAL_ID=
CECABANK_SECRET_KEY=
CECABANK_SANDBOX=true
PAYMENT_WEBHOOK_SECRET=

# Super Admin (comma-separated emails that can manage module toggles)
SUPER_ADMIN_EMAILS=admin@example.com

# WhatsApp
NEXT_PUBLIC_WHATSAPP_NUMBER=34XXXXXXXXX

# Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
